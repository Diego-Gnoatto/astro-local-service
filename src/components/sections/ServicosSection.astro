---
import { SERVICES, CONTACT } from '../../lib/constants';
---

<section id="servicos" class="section-padding bg-dark-light">
  <div class="container-main">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Nossos Servicos</h2>
    <p class="text-white/60 text-center max-w-2xl mx-auto mb-12">{{SERVICES_INTRO}}</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {SERVICES.map((service) => (
        <a href={`/${service.slug}/`} class="block p-6 bg-dark rounded-xl border border-white/10 hover:border-primary transition-all duration-300 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-lg bg-primary/20 flex items-center justify-center mb-4">
            <span class="text-2xl">{{SERVICE_ICON}}</span>
          </div>
          <h3 class="text-xl font-bold mb-2">{service.name}</h3>
          <p class="text-white/60 text-sm">{service.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
