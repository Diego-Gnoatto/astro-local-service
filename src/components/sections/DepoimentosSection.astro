---

<section id="depoimentos" class="section-padding bg-dark-light">
  <div class="container-main">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">O que nossos clientes dizem</h2>
    <p class="text-white/60 text-center max-w-2xl mx-auto mb-12">{{TESTIMONIALS_INTRO}}</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
      <!-- Replace with real testimonials from constants.ts -->
      <div class="p-6 bg-dark rounded-xl border border-white/10">
        <div class="flex items-center gap-1 mb-4">
          {[...Array(5)].map(() => (
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <p class="text-white/70 mb-4">{{TESTIMONIAL_PLACEHOLDER}}</p>
        <p class="text-sm text-white/50">{{TESTIMONIAL_AUTHOR_PLACEHOLDER}}</p>
      </div>
      <!-- Repeat for more testimonials -->
    </div>
  </div>
</section>
