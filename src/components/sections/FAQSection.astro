---
import { FAQ } from '../../lib/constants';
---

<section id="faq" class="section-padding bg-dark-light">
  <div class="container-main max-w-3xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Perguntas Frequentes</h2>
    <p class="text-white/60 text-center max-w-2xl mx-auto mb-12">{{FAQ_INTRO}}</p>
    <div class="space-y-4 stagger-children">
      {FAQ.map((item, index) => (
        <details class="group p-6 bg-dark rounded-xl border border-white/10">
          <summary class="flex items-center justify-between cursor-pointer font-semibold text-lg">
            {item.question}
            <span class="text-primary group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="mt-4 text-white/70">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
